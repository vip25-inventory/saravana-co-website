{
  "version": 2,
  "builds": [
    {
      "src": "django_backend/api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "django_backend/api/index.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "saravanaco.settings",
    "VERCEL": "1"
  }
}
