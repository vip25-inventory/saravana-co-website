# =============================================
# Saravana & Co - Environment Configuration
# =============================================
# ⚠️  NEVER commit this file to git!
# Copy this to .env and fill in real values.

PORT=8000

# Django
DJANGO_SETTINGS_MODULE=saravanaco.settings
# Set to "true" only for local development
DJANGO_DEBUG=true
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-strong-random-secret-key-at-least-50-chars

# Frontend origin (no trailing slash)
ALLOWED_ORIGIN=http://localhost:8000

# MongoDB
# Replace with your actual Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=saravanaco

# JWT — keep same as SECRET_KEY or use a separate strong random string
JWT_SECRET=replace-with-a-strong-jwt-secret

# Admin default credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@1234
